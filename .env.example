# Copy to .env and fill in. Never commit .env.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=blackbox
POSTGRES_PASSWORD=blackbox
POSTGRES_DB=blackbox
DATABASE_URL=postgresql://blackbox:blackbox@localhost:5432/blackbox

# LLM provider (OpenAI-compatible; point base_url at Gemini/Ollama/etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=
JUDGE_MODEL=

# Embedding model (local, sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Langfuse (optional)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
