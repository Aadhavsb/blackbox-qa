# Copy to .env and fill in. Never commit .env.

# Postgres (matches docker-compose.yml defaults)
POSTGRES_USER=blackbox
POSTGRES_PASSWORD=blackbox
POSTGRES_DB=blackbox
DATABASE_URL=postgresql://blackbox:blackbox@localhost:5432/blackbox

# LLM provider (OpenAI-compatible; point base_url at Gemini/Ollama/etc.)
# Free path: a Google AI Studio key (https://aistudio.google.com/apikey) + the
# Gemini OpenAI-compat endpoint below. Note: some models (e.g. gemini-2.0-flash)
# may show free-tier quota 0 on a given key — gemini-2.5-flash works on free tier.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
JUDGE_MODEL=gemini-2.5-pro

# Embedding + reranker models (local, sentence-transformers — free, no API)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Langfuse (optional)
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
